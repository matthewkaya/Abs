# Demo (customer-journey) tenant placeholder keys.
# Sprint 20 free-tier refactor — paid SaaS keys are removed; opt-in flags must
# be set explicitly to enable Claude / Recall / ElevenLabs.
# All values are PLACEHOLDERS — replace with sandbox keys before running.
# Rotated on every `python scripts/purge_demo_tenant.py` invocation.

ABS_TENANT_ID=demo-acme
ABS_TENANT_NAME="Demo Acme (Customer Journey)"

# Required (free tier) — generous free quotas
GROQ_API_KEY=replace-with-groq-key
# Cloudflare provider — pydantic prefix ABS_ + field cf_*. Round-4 fix:
# unprefixed CF_* was silently ignored by the cascade resolver.
ABS_CF_ACCOUNT_ID=replace-with-cf-account-id
ABS_CF_API_TOKEN=replace-with-cf-api-token
TEST_GEMINI_API_KEY=replace-with-gemini-key
TEST_GMAIL_OAUTH_CLIENT_ID=replace-with-google-cloud-test-client-id
TEST_GMAIL_OAUTH_CLIENT_SECRET=replace-with-google-cloud-test-client-secret

# Optional (opt-in only — paid SaaS, default OFF)
# Each requires the matching ABS_*_ENABLED flag.
ABS_ANTHROPIC_ENABLED=false
# ABS_ANTHROPIC_API_KEY=
ABS_RECALL_ENABLED=false
# ABS_RECALL_AI_API_KEY=
ABS_ELEVENLABS_ENABLED=false
# ABS_ELEVENLABS_API_KEY=

# Claude monthly quota (used only when ANTHROPIC_ENABLED=true)
ABS_CLAUDE_MONTHLY_TOKEN_LIMIT=1000000
ABS_CLAUDE_QUOTA_WARN_PCT=0.80
ABS_CLAUDE_QUOTA_BLOCK_PCT=0.95

# Free-tier meeting + TTS backends (T-F01, T-F02)
ABS_RECALL_BACKEND=local
ABS_MEETING_LOCAL_RUNNER=meetily
ABS_TRANSCRIBE_BACKEND=whisperx
ABS_TTS_BACKEND=coqui
ABS_TTS_AUTO_FALLBACK=true

# Stripe TEST mode (no live charges)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_replace
STRIPE_TEST_SECRET_KEY=sk_test_replace

# Cerbos PDP
CERBOS_HOST=http://localhost:3592
