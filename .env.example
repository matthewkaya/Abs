# ABS Server Product — root environment variable index.
#
# This monorepo splits env into per-service files. Use the closest one:
#
#   core/backend/.env.example   → FastAPI service (ABS_* prefix; Pydantic Settings)
#   core/landing/.env.example   → Next.js app (NEXT_PUBLIC_* + landing-specific)
#   infra/docker-compose.dev.yml → dev compose overlay (also reads root .env)
#
# `infra/docker-compose.*.yml` files load the project root `.env` automatically
# when invoked from this directory. Variables defined here are shared across
# both stacks (e.g. domain, deployment env).
#
# Production boot guard (T-Q01): when ABS_ENV=prod the backend refuses to boot
# if any **REQUIRED in prod** secret in core/backend/.env.example is left at
# its dev-insecure default. See `core/backend/app/config.py:_assert_prod_safe`.
#
# ─── Shared (root) ─────────────────────────────────────────────────────────
ABS_ENV=dev                              # "dev" | "prod"
ABS_DOMAIN=abs.local                     # used by Caddy + Next.js public URL
COMPOSE_PROJECT_NAME=abs                 # docker compose project namespace

# ─── Backend (mirror of core/backend/.env.example highlights) ─────────────
# Full inventory: see core/backend/.env.example (94 lines, 30+ vars)
ABS_ADMIN_EMAIL=admin@example.com
ABS_DATABASE_URL=sqlite:////app/data/abs.db
ABS_LICENSE_KEY=
ABS_STRIPE_SECRET_KEY=sk_test_...
ABS_STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Landing (mirror of core/landing/.env.example highlights) ─────────────
# Full inventory: see core/landing/.env.example
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─── Demo + dev overlays ──────────────────────────────────────────────────
# infra/docker-compose.demo.yml ships dummy values (`whsec_demo_dummy`, etc.)
# for local seed runs. Production deploys never load that file.
