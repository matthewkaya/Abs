# Automatia ABS — customer environment.
# Copy: cp .env.example .env  (then fill the blanks below).
# Quickstart: https://github.com/automatiabcn/abs/blob/main/docs/quickstart-30min.md
# Developer monorepo? See core/backend/.env.example (FastAPI) and
# core/landing/.env.example (Next.js) instead — those are the per-service
# inventories with every internal flag.
#
# How `.env` is loaded:
#   docker compose -f infra/docker-compose.customer.yml up -d
# The customer compose's env_file paths resolve next to the compose file,
# so this template doubles as a stub for both root and infra/ workflows.
# If the compose can't find your .env, copy it to infra/.env as well:
#   cp .env infra/.env

# === Required (5) =========================================================
# JWT token from the "Your ABS license is ready" email. Paste the full
# token on a single line, no quotes. The backend phones home at boot.
ABS_LICENSE_KEY=

# Your domain (e.g. abs.mycompany.com) or, for a no-DNS smoke test,
# a sslip.io alias such as 203-0-113-7.sslip.io.
ABS_PUBLIC_HOSTNAME=

# Full https URL — Next.js needs this for absolute links + canonical tags.
ABS_PUBLIC_URL=

# Contact email for Let's Encrypt cert renewal notices (Caddy ACME).
ABS_ACME_EMAIL=

# 32-byte base64 key encrypting the local secret vault (provider keys,
# OAuth state). Generate once, then keep an offsite backup:
#   openssl rand -base64 32
ABS_VAULT_KEY=

# === Provider API keys (paste at least one paid provider) =================
# Order below mirrors the cascade priority. Anthropic recommended for
# the best ABS experience; the others slot in as fallbacks.
ANTHROPIC_API_KEY=                    # https://console.anthropic.com/settings/keys
OPENAI_API_KEY=                       # https://platform.openai.com/api-keys (optional)
GROQ_API_KEY=                         # https://console.groq.com/keys (free tier, fast)
GEMINI_API_KEY=                       # https://aistudio.google.com/app/apikey (free tier)
CEREBRAS_API_KEY=                     # https://cloud.cerebras.ai/ (optional)
COHERE_API_KEY=                       # https://dashboard.cohere.com/api-keys (free tier)

# === Image version (don't change unless support tells you) ===============
ABS_VERSION=1.0.0-rc2

# === Optional — leave blank for defaults =================================
# ABS_DOMAIN=                         # alias for ABS_PUBLIC_HOSTNAME
# ABS_ADMIN_EMAIL=                    # admin user bootstrap email
# RESEND_API_KEY=                     # transactional emails (welcome, refund) — optional
# STRIPE_SECRET_KEY=                  # only if you want to monetize your own ABS instance
# ABS_STRIPE_WEBHOOK_SECRET=          # paired with STRIPE_SECRET_KEY (whsec_...)
