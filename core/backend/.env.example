# ABS backend — environment variable inventory.
# Copy to `.env` and fill real values. Pydantic Settings reads env_prefix=ABS_
# so each variable below is the name pydantic expects in env.
#
# T-Q01: in production (ABS_ENV=prod) the backend refuses to boot if any of the
# secrets marked "**REQUIRED in prod**" is left at its dev-insecure default.

# ─── Core ─────────────────────────────────────────────────────────────────
ABS_ENV=dev                          # "dev" | "prod"
ABS_ADMIN_EMAIL=admin@example.com
ABS_DOMAIN=abs.local
ABS_SSL_MODE=internal                # "internal" | "acme"
ABS_DATABASE_URL=sqlite:////app/data/abs.db
ABS_DATA_DIR=/app/data

# ─── Licensing keys ───────────────────────────────────────────────────────
ABS_LICENSE_KEY=
ABS_PRIVATE_KEY_PATH=/app/data/private.pem
ABS_PUBLIC_KEY_PATH=/app/data/public.pem

# ─── Stripe (billing) ─────────────────────────────────────────────────────
ABS_STRIPE_SECRET_KEY=sk_test_...
ABS_STRIPE_WEBHOOK_SECRET=whsec_...
ABS_PRICE_SELF_HOST=
ABS_PRICE_TEAM_5=
ABS_PRICE_TEAM_10=

# ─── SMTP (empty → email goes to console) ─────────────────────────────────
ABS_SMTP_HOST=
ABS_SMTP_PORT=587
ABS_SMTP_USER=
ABS_SMTP_PASSWORD=
ABS_SMTP_FROM=noreply@automatiabcn.com

# ─── Secrets (REQUIRED in prod — boot will fail with dev defaults) ────────
ABS_UNSUBSCRIBE_JWT_SECRET=          # **REQUIRED in prod**
ABS_ADMIN_TOKEN=                     # **REQUIRED in prod**
ABS_AUDIT_IP_SALT=                   # **REQUIRED in prod**
ABS_DELETE_CONFIRM_JWT_SECRET=       # **REQUIRED in prod**
ABS_BETA_ADMIN_TOKEN=                # **REQUIRED in prod**
ABS_ADMIN_JWT_SECRET=                # **REQUIRED in prod**
ABS_SESSION_SECRET=                  # **REQUIRED in prod**
ABS_ADMIN_PASSWORD_BOOTSTRAP=        # **REQUIRED in prod**
ABS_VAULT_AUDIT_HMAC_SECRET=         # **REQUIRED in prod**
ABS_ADMIN_PASSWORD_HASH=             # bcrypt hash; empty = login disabled

# ─── Webhooks / signing ───────────────────────────────────────────────────
ABS_DISCORD_WEBHOOK_URL=
ABS_SLACK_SIGNING_SECRET=
ABS_GITHUB_APP_ID=
ABS_GITHUB_APP_PRIVATE_KEY=
ABS_GITHUB_APP_WEBHOOK_SECRET=

# ─── Rate limiting ────────────────────────────────────────────────────────
ABS_RATE_LIMIT_ENABLED=true
ABS_RATE_LIMIT_STORAGE_URI=memory://     # prod: redis://abs-redis-master:6379/0

# ─── X-ABS-Audience enforcement (T-058 caveat #11) ────────────────────────
ABS_AUDIENCE_ENFORCE=false               # prod helm flips to true
ABS_AUDIENCE_VALUE=abs-mcp

# ─── AI providers (cascade) ───────────────────────────────────────────────
ABS_ANTHROPIC_API_KEY=
ABS_GROQ_API_KEY=
ABS_CEREBRAS_API_KEY=
ABS_GEMINI_API_KEY=
ABS_CF_ACCOUNT_ID=
ABS_CF_API_TOKEN=
ABS_COHERE_API_KEY=
ABS_OPENROUTER_API_KEY=
ABS_VLLM_URL=
ABS_OLLAMA_URL=
ABS_MLX_URL=

# ─── SaaS integrations (T-Q03) ────────────────────────────────────────────
ABS_GMAIL_OAUTH_CLIENT_ID=
ABS_GMAIL_OAUTH_CLIENT_SECRET=
ABS_GMAIL_OAUTH_REDIRECT=
ABS_RECALL_API_KEY=
ABS_DEEPGRAM_API_KEY=
ABS_WHISPERX_DEVICE=cpu
# Transcription backend: mock | whisperx | deepgram | groq
# "groq" = cloud Whisper via your Groq key (BYOK) — no local whisperx container,
# GPU or disk. Diarization is whisperx-only; groq returns a single speaker.
ABS_TRANSCRIBE_BACKEND=mock
ABS_GROQ_WHISPER_MODEL=whisper-large-v3
ABS_ELEVENLABS_API_KEY=
ABS_ELEVENLABS_VOICE_ID=

# ─── GraphRAG (Phase 2 — knowledge graph over the RAG corpus) ─────────────
# Opt-in. When false, /v1/graph-rag/* return 404. When true, /v1/graph-rag/build
# extracts entities/relations into Neo4j and /v1/graph-rag/query does hybrid
# (vector + 1-hop subgraph) retrieval with grounded synthesis.
ABS_GRAPHRAG_ENABLED=false
ABS_GRAPHRAG_BUILD_MAX_CHUNKS=500

# ─── Multi-tenant — per-owner provider keys (Phase 1 data layer) ──────────
# At-rest encryption for DB-stored provider keys. MUST be set in production
# (any string; sha256-derived Fernet key). Unset → insecure base64 fallback.
ABS_PROVIDER_KEY_ENCRYPTION_KEY=

# ─── Vault / sops + age ───────────────────────────────────────────────────
ABS_VAULT_KEY_PATH=/app/vault-key/age.key
ABS_VAULT_SECRETS_PATH=/app/data/secrets.yaml
ABS_VAULT_REQUIRE_SOPS=false
ABS_VAULT_MIN_SOPS_VERSION=3.7.0

# ─── State / multi-replica (T-058) ────────────────────────────────────────
ABS_STATE_BACKEND=sqlite                  # "sqlite" | "postgres"
ABS_STATE_POSTGRES_URL=
ABS_STATE_REDIS_URL=

# ─── Tier list prices (Q12-R84) ───────────────────────────────────────────
# USD/month. Default 0.0 = pricing not configured. Operators set these in
# their own .env. Tier IDs ("self-host", "team-5", "team-10") are SKU keys
# and remain in code; only dollar amounts are extracted.
ABS_SEAT_PRICE_SELF_HOST=0.0              # e.g. 299.0
ABS_SEAT_PRICE_TEAM_5=0.0                 # e.g. 1196.0 (~$239/seat)
ABS_SEAT_PRICE_TEAM_10=0.0                # e.g. 2093.0 (~$209/seat)
ABS_REVENUE_WIDGET_MULTIPLIER=0.0         # admin dashboard heuristic ($/mo per active license)
ABS_MAINTENANCE_PRICE_YEARLY=0.0          # maintenance add-on (used in expiry_warning emails)
ABS_ANNUAL_OFFER_STRIKE=0.0               # beta_renewal_offer strike-through price
ABS_ANNUAL_OFFER_PRICE=0.0                # beta_renewal_offer discounted price
