{
  "$schema": "https://www.inngest.com/schema/app.json",
  "appId": "abs-backend",
  "framework": "fastapi",
  "servePath": "/api/inngest",
  "description": "ABS backend durable workflow app (T-002).",
  "functions": [
    {
      "id": "on_user_registered",
      "trigger": { "event": "abs/user.registered" },
      "retries": 4,
      "description": "Bridge of NATS abs.events.user.registered to durable onboarding pipeline."
    }
  ],
  "dev": {
    "command": "npx inngest-cli@latest dev",
    "url": "http://localhost:8000/api/inngest",
    "notes": "Backend must be running locally before starting the Inngest dev server."
  }
}
