{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/panel",
        "http://localhost:3000/panel/chat",
        "http://localhost:3000/panel/tools",
        "http://localhost:3000/admin/providers",
        "http://localhost:3000/admin/pipelines",
        "http://localhost:3000/admin/rag",
        "http://localhost:3000/admin/marketplace",
        "http://localhost:3000/panel/quota",
        "http://localhost:3000/admin/graph",
        "http://localhost:3000/admin/settings",
        "http://localhost:3000/admin/audit",
        "http://localhost:3000/admin/users",
        "http://localhost:3000/panel/meetings",
        "http://localhost:3000/panel/transcription",
        "http://localhost:3000/admin/workflow-builder"
      ],
      "startServerCommand": "npx next start",
      "startServerReadyPattern": "ready in",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "extraHeaders": "{\"Cookie\":\"abs_session=${ABS_PANEL_COOKIE}\"}"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.15 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
