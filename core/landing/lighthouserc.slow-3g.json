{
  "_comment": "Q12-L32 R82 — slow-3G mobile profile. The desktop lighthouserc.json runs from perf-budget on PR; this profile runs nightly so a mobile regression has a clear daily signal. Throttling thresholds are intentionally looser than desktop because slow-3G shifts LCP/TBT into a different working region; the goal is `regression detection`, not desktop parity. Sprint 2E ITEM-C: dropped `preset: perf` (which skipped a11y / best-practices audits → `categories:accessibility auditRan` failed); replaced with explicit `onlyCategories` so the asserted categories actually run.",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/pricing",
        "http://localhost:3000/showcase",
        "http://localhost:3000/onboarding"
      ],
      "startServerCommand": "cd core/landing && npx next start",
      "startServerReadyPattern": "ready in",
      "numberOfRuns": 3,
      "settings": {
        "onlyCategories": ["performance", "accessibility", "best-practices"],
        "throttlingMethod": "devtools",
        "throttling": {
          "rttMs": 300,
          "throughputKbps": 400,
          "cpuSlowdownMultiplier": 4,
          "requestLatencyMs": 0,
          "downloadThroughputKbps": 0,
          "uploadThroughputKbps": 0
        },
        "emulatedFormFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 360,
          "height": 640,
          "deviceScaleFactor": 2,
          "disabled": false
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.55 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 8000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.15 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 1500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
