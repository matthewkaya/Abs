# Automatia ABS — infra env
# install.sh bu dosyayı .env olarak kopyalar. Değerleri üretimde mutlaka doldurun.

# --- Genel ---
ABS_ADMIN_EMAIL=admin@example.com
ABS_DOMAIN=abs.local
# "internal" = self-signed (dev), "acme" = Let's Encrypt (prod)
ABS_SSL_MODE=internal
ABS_ENV=dev

# --- Lisans (müşteri tarafında doldurulur) ---
ABS_LICENSE_KEY=

# --- Lisans anahtarları (bizim taraf; public key müşteri image'ına gömülür) ---
ABS_PRIVATE_KEY_PATH=/app/data/private.pem
ABS_PUBLIC_KEY_PATH=/app/data/public.pem

# --- Stripe (bizim taraf: billing sunucusu) ---
ABS_STRIPE_SECRET_KEY=sk_test_...
ABS_STRIPE_WEBHOOK_SECRET=whsec_...

# --- SMTP (boşsa email console'a yazılır) ---
ABS_SMTP_HOST=
ABS_SMTP_PORT=587
ABS_SMTP_USER=
ABS_SMTP_PASSWORD=
ABS_SMTP_FROM=noreply@automatiabcn.com

# --- DB ---
ABS_DATABASE_URL=sqlite:////app/data/abs.db

# --- MCP Provider API anahtarları (005) ---
# Gerçek key'leri .env'e yazın; .env.example COMMIT edilir, .env edilmez.
ABS_ANTHROPIC_API_KEY=
ABS_GROQ_API_KEY=
ABS_CEREBRAS_API_KEY=
ABS_GEMINI_API_KEY=
ABS_CF_ACCOUNT_ID=
ABS_CF_API_TOKEN=
ABS_COHERE_API_KEY=
ABS_OLLAMA_URL=

# MVP: false (demo mode serbest); 008'de true ile lisans zorunlu yap.
ABS_MCP_REQUIRE_LICENSE=false

# --- Hooks (007) ---
ABS_HOOKS_ENABLED=true
ABS_HOOKS_MODE=middleware  # middleware | native | both
ABS_CACHE_DIR=/app/data/cache
ABS_ARTIFACTS_DIR=/app/data/artifacts
