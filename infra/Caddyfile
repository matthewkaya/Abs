{
	# dev: tls internal (self-signed). prod'da abs.local'i public domain ile değiştirince
	# Caddy otomatik ACME'ye geçer — ekstra config gerekmez.
	admin off
}

abs.local {
	tls internal

	# Brief 4 R3 — route split:
	#   API + setup wizard + auth + MCP transport → backend (FastAPI 8000)
	#   Everything else (landing pages + admin Next.js) → landing (Next 3000)

	@backend path /v1/* /auth/* /setup* /healthz /mcp* /static/* /panel /panel/*
	handle @backend {
		reverse_proxy backend:8000
	}

	# /api/inngest is mounted on the FastAPI backend (T-002), keep it
	# server-side so the Inngest dev server can serve discovery requests.
	@inngest path /api/inngest /api/inngest/*
	handle @inngest {
		reverse_proxy backend:8000
	}

	# Default: marketing pages + Next.js admin under /admin/*
	handle {
		reverse_proxy landing:3000
	}
}
